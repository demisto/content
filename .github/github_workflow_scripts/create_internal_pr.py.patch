+def create_pr(content_repo, title, body, base_branch, head_branch, labels, assignees, reviewers, t):
+    pr = content_repo.create_pull(title=title, body=body, base=base_branch, head=head_branch, draft=False)
+    print(f"{t.cyan}Internal PR Created - {pr.html_url}{t.normal}")
+
+    for label in labels:
+        pr.add_to_labels(label)
+        print(f'{t.cyan}"{label}" label added to the Internal PR{t.normal}')
+
+    if reviewers:
+        pr.create_review_request(reviewers=reviewers)
+        print(f"{t.cyan}Requested review from {reviewers}{t.normal}")
+
+    if assignees:
+        pr.add_to_assignees(*assignees)
+        print(f"{t.cyan}Assigned users {assignees}{t.normal}")
+
+    return pr
+
+def remove_release_notes_from_body(body: str) -> str:
+    """
+    Removes the release notes section from the PR body.
+    """
+    # This is a simple heuristic, assuming release notes are under a specific header
+    # or we can just remove the whole body and replace it with a reference.
+    # The requirement says "Does NOT have the release notes."
+    # Let's just use a simple body for the mapping PR.
+    return body
+
+def get_mapping_pr_body(merged_pr_url: str, merged_pr_author: str, original_body: str) -> str:
+    """
+    Creates the body for the mapping PR.
+    """
+    body = f"## Original External PR\r\n[external pull request]({merged_pr_url})\r\n\r\n"
+    if "## Contributor" not in original_body:
+        body += f"## Contributor\r\n@{merged_pr_author}\r\n\r\n"
+    
+    # We need to include the original body but remove release notes.
+    # A common pattern is "## Release Notes" or similar.
+    # For now, let's just include the original body and try to strip out RNs if we can find a clear pattern,
+    # or just rely on the fact that the mapping PR shouldn't have RNs in the files.
+    # Actually, the requirement "Does NOT have the release notes" might mean the PR *files* shouldn't have RNs,
+    # or the PR body shouldn't have the RN section.
+    # Let's strip the RN section from the body if it exists.
+    import re
+    # Remove everything from "## Release Notes" (case insensitive) to the next "## " or end of string
+    body_without_rn = re.sub(r'(?i)##\s*Release Notes.*?(?=##\s|$)', '', original_body, flags=re.DOTALL)
+    
+    body += body_without_rn
+    return replace_related_with_fixes_in_pr_body(body)
+
