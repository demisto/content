{
    "description": "Maps Sysdig Secure V2 webhook payload fields to Sysdig Runtime Event incident fields.",
    "id": "Sysdig Mapper Runtime Event",
    "mapping": {
        "Sysdig Runtime Event": {
            "dontMapEventToLabels": true,
            "internalMapping": {
                "Sysdig Container ID": {
                    "simple": "entities.[0].policyEvents.[0].containerId"
                },
                "Source Hostname": {
                    "simple": "entities.[0].policyEvents.[0].eventLabels.host\\.hostName"
                },
                "MAC Address": {
                    "simple": "entities.[0].policyEvents.[0].hostMac"
                },
                "name": {
                    "simple": "entities.[0].policyEvents.[0].ruleName"
                },
                "severity": {
                    "complex": {
                        "root": "alert.severity",
                        "filters": [],
                        "transformers": [
                            {
                                "operator": "MapValuesTransformer",
                                "args": {
                                    "input_values": {
                                        "isContext": false,
                                        "value": {
                                            "complex": null,
                                            "simple": "0,1,2,3,4,5,6,7"
                                        }
                                    },
                                    "mapped_values": {
                                        "isContext": false,
                                        "value": {
                                            "complex": null,
                                            "simple": "4,4,3,3,2,2,1,1"
                                        }
                                    }
                                }
                            }
                        ]
                    }
                },
                "occurred": {
                    "complex": {
                        "root": "timestamp",
                        "filters": [],
                        "transformers": [
                            {
                                "operator": "TimeStampToDate"
                            }
                        ]
                    }
                },
                "details": {
                    "simple": "alert.body"
                },
                "dbotMirrorId": {
                    "simple": "entities.[0].policyEvents.[0].id"
                },
                "Sysdig Event ID": {
                    "simple": "entities.[0].policyEvents.[0].id"
                },
                "Sysdig Rule Name": {
                    "simple": "entities.[0].policyEvents.[0].ruleName"
                },
                "Sysdig Rule Type": {
                    "simple": "entities.[0].policyEvents.[0].ruleType"
                },
                "Sysdig Policy ID": {
                    "simple": "entities.[0].policyEvents.[0].policyId"
                },
                "Sysdig Policy Name": {
                    "simple": "entities.[0].policies.[0].name"
                },
                "Sysdig Policy Version": {
                    "simple": "entities.[0].policyEvents.[0].policyVersion"
                },
                "Sysdig Falco Output": {
                    "simple": "entities.[0].policyEvents.[0].output"
                },
                "Sysdig Event URL": {
                    "simple": "event.url"
                },
                "Sysdig Source": {
                    "simple": "source"
                },
                "Sysdig Origin": {
                    "simple": "entities.[0].policyEvents.[0].origin"
                },
                "Sysdig Aggregated": {
                    "simple": "entities.[0].policyEvents.[0].isAggregated"
                },
                "Sysdig Container Name": {
                    "simple": "entities.[0].policyEvents.[0].eventLabels.container\\.name"
                },
                "Sysdig Container Image": {
                    "simple": "entities.[0].policyEvents.[0].eventLabels.container\\.image\\.repo"
                },
                "Sysdig Container Image Tag": {
                    "simple": "entities.[0].policyEvents.[0].eventLabels.container\\.image\\.tag"
                },
                "Sysdig Container Image ID": {
                    "simple": "entities.[0].policyEvents.[0].eventLabels.container\\.image\\.id"
                },
                "Sysdig Host ID": {
                    "simple": "entities.[0].policyEvents.[0].eventLabels.host\\.id"
                },
                "Sysdig Agent Version": {
                    "simple": "entities.[0].policyEvents.[0].eventLabels.agent\\.version"
                },
                "Sysdig Agent Variant": {
                    "simple": "entities.[0].policyEvents.[0].eventLabels.agent\\.variant"
                },
                "Sysdig K8s Cluster Name": {
                    "simple": "entities.[0].policyEvents.[0].eventLabels.kubernetes\\.cluster\\.name"
                },
                "Sysdig K8s Namespace": {
                    "simple": "entities.[0].policyEvents.[0].eventLabels.kubernetes\\.namespace\\.name"
                },
                "Sysdig K8s Pod Name": {
                    "simple": "entities.[0].policyEvents.[0].eventLabels.kubernetes\\.pod\\.name"
                },
                "Sysdig K8s Node Name": {
                    "simple": "entities.[0].policyEvents.[0].eventLabels.kubernetes\\.node\\.name"
                },
                "Sysdig K8s Workload Name": {
                    "simple": "entities.[0].policyEvents.[0].eventLabels.kubernetes\\.workload\\.name"
                },
                "Sysdig K8s Workload Type": {
                    "simple": "entities.[0].policyEvents.[0].eventLabels.kubernetes\\.workload\\.type"
                },
                "Sysdig AWS Account ID": {
                    "simple": "entities.[0].policyEvents.[0].eventLabels.aws\\.accountId"
                },
                "Sysdig AWS Region": {
                    "simple": "entities.[0].policyEvents.[0].eventLabels.aws\\.region"
                },
                "Sysdig AWS Instance ID": {
                    "simple": "entities.[0].policyEvents.[0].eventLabels.aws\\.instanceId"
                },
                "Sysdig Process Name": {
                    "simple": "entities.[0].policyEvents.[0].fields.proc\\.name"
                },
                "Sysdig Process Cmdline": {
                    "simple": "entities.[0].policyEvents.[0].fields.proc\\.cmdline"
                },
                "Sysdig Process CWD": {
                    "simple": "entities.[0].policyEvents.[0].fields.proc\\.cwd"
                },
                "Sysdig Process SHA256": {
                    "simple": "entities.[0].policyEvents.[0].fields.proc\\.hash\\.sha256"
                },
                "Sysdig Process Parent Name": {
                    "simple": "entities.[0].policyEvents.[0].fields.proc\\.pname"
                },
                "Sysdig Event Type": {
                    "simple": "entities.[0].policyEvents.[0].fields.evt\\.type"
                },
                "Sysdig Username": {
                    "simple": "entities.[0].policyEvents.[0].fields.user\\.name"
                }
            }
        }
    },
    "name": "Sysdig Mapper Runtime Event",
    "type": "mapping-incoming",
    "version": -1,
    "fromVersion": "6.10.0",
    "feed": false,
    "defaultIncidentType": "Sysdig Runtime Event"
}