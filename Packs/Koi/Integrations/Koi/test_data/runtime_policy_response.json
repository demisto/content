{
  "id": "rp-1",
  "display_name": "Block unsigned binaries",
  "description": "Prevents execution of unsigned binaries on managed endpoints",
  "agents": 120,
  "enforcement_mode": "enforce",
  "enabled": true,
  "group_ids": [1, 2],
  "created_by": "admin@example.com",
  "created_at": "2025-01-10T10:00:00Z",
  "updated_at": "2025-03-01T12:00:00Z",
  "rules": [
    {
      "id": "rule-1",
      "type": "binary_signature",
      "action": "block",
      "condition": "signature == unsigned"
    },
    {
      "id": "rule-2",
      "type": "network",
      "action": "alert",
      "condition": "destination ~= mcp"
    }
  ]
}
