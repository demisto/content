1016", XDM_CONST.MITRE_TECHNIQUE_SYSTEM_NETWORK_CONFIGURATION_DISCOVERY, "@element" = "T1049", XDM_CONST.MITRE_TECHNIQUE_SYSTEM_NETWORK_CONNECTIONS_DISCOVERY, "@element" = "T1033", XDM_CONST.MITRE_TECHNIQUE_SYSTEM_OWNER_USER_DISCOVERY, "@element" = "T1007", XDM_CONST.MITRE_TECHNIQUE_SYSTEM_SERVICE_DISCOVERY, "@element" = "T1569", XDM_CONST.MITRE_TECHNIQUE_SYSTEM_SERVICES, "@element" = "T1529", XDM_CONST.MITRE_TECHNIQUE_SYSTEM_SHUTDOWN_OR_REBOOT, "@element" = "T1124", XDM_CONST.MITRE_TECHNIQUE_SYSTEM_TIME_DISCOVERY, "@element" = "T1080", XDM_CONST.MITRE_TECHNIQUE_TAINT_SHARED_CONTENT, "@element" = "T1221", XDM_CONST.MITRE_TECHNIQUE_TEMPLATE_INJECTION, "@element" = "T1205", XDM_CONST.MITRE_TECHNIQUE_TRAFFIC_SIGNALING, "@element" = "T1537", XDM_CONST.MITRE_TECHNIQUE_TRANSFER_DATA_TO_CLOUD_ACCOUNT, "@element" = "T1127", XDM_CONST.MITRE_TECHNIQUE_TRUSTED_DEVELOPER_UTILITIES_PROXY_EXECUTION, "@element" = "T1199", XDM_CONST.MITRE_TECHNIQUE_TRUSTED_RELATIONSHIP, "@element" = "T1111", XDM_CONST.MITRE_TECHNIQUE_TWO_FACTOR_AUTHENTICATION_INTERCEPTION, "@element" = "T1552", XDM_CONST.MITRE_TECHNIQUE_UNSECURED_CREDENTIALS, "@element" = "T1535", XDM_CONST.MITRE_TECHNIQUE_UNSUPPORTED_CLOUD_REGIONS, "@element" = "T1550", XDM_CONST.MITRE_TECHNIQUE_USE_ALTERNATE_AUTHENTICATION_MATERIAL, "@element" = "T1204", XDM_CONST.MITRE_TECHNIQUE_USER_EXECUTION, "@element" = "T1078", XDM_CONST.MITRE_TECHNIQUE_VALID_ACCOUNTS, "@element" = "T1497", XDM_CONST.MITRE_TECHNIQUE_SANDBOX_EVASION, "@element" = "T1125", XDM_CONST.MITRE_TECHNIQUE_VIDEO_CAPTURE, "@element" = "T1600", XDM_CONST.MITRE_TECHNIQUE_WEAKEN_ENCRYPTION, "@element" = "T1102", XDM_CONST.MITRE_TECHNIQUE_WEB_SERVICE, "@element" = "T1047", XDM_CONST.MITRE_TECHNIQUE_WINDOWS_MANAGEMENT_INSTRUMENTATION, "@element" = "T1220", XDM_CONST.MITRE_TECHNIQUE_XSL_SCRIPT_PROCESSING, "@element"))
| alter
    // =====================================================================
    // PART 3: FINAL XDM MAPPING
    // =====================================================================
    xdm.alert.original_alert_id = alertId,
    xdm.alert.name = name,
    xdm.alert.severity = tmp_priority,
    xdm.alert.subcategory = arraystring(tmp_use_cases_list, ", "),
    xdm.alert.description = arrayindex(tmp_rule_names, 0),
    xdm.alert.original_threat_id = arraystring(tmp_rule_ids, ", "),
    xdm.event.description = arrayindex(tmp_rule_reasons, 0),
    xdm.alert.mitre_tactics = tmp_mitre_tactics,
    xdm.alert.mitre_techniques = tmp_mitre_techniques,
    xdm.source.host.ipv4_addresses = tmp_src_ipv4_list,
    xdm.source.host.ipv6_addresses = tmp_src_ipv6_list,
    xdm.target.host.ipv4_addresses = tmp_dest_ipv4_list,
    xdm.target.host.ipv6_addresses = tmp_dest_ipv6_list,
    xdm.source.host.hostname = arraystring(tmp_src_host_list, ", "),
    xdm.target.host.hostname = arraystring(tmp_dest_host_list, ", "),
    xdm.source.user.username = arraystring(tmp_user_list, ", ");