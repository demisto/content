{
  "name": "headless-browser-renderer",
  "version": "2.0.0",
  "description": "Memory-aware headless browser CLI tool for batch URL screenshot capture",
  "main": "dist/index.js",
  "type": "module",
  "bin": {
    "render-cli": "dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:unit": "vitest run tests/unit",
    "test:integration": "vitest run tests/integration",
    "lint": "tsc --noEmit"
  },
  "dependencies": {
    "playwright": "^1.52.0",
    "pino": "^9.6.0",
    "uuid": "^11.1.0"
  },
  "devDependencies": {
    "typescript": "^5.7.3",
    "vitest": "^3.1.1",
    "@types/node": "^22.15.3",
    "@types/uuid": "^10.0.0",
    "tsx": "^4.19.4"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
