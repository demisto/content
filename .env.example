# =============================================================================
# Unified Cortex Platform (UCP) — root environment example
# =============================================================================
# This is the consolidated env example for the UCP / connectus tooling in this
# repo. It unifies the environment variables previously scattered across the
# `connectus/` tooling (param-parity runtime, generate-manifest flow, and the
# validate gates).
#
# USAGE:
#   1. Copy this file to `.env` at the repo root:  cp .env.example .env
#   2. Fill in the REQUIRED values for your tenant / workspace.
#   3. NEVER commit real secrets — the placeholders below are safe examples.
#
# NOTE: One tenant per shell. Set TENANT_ID to YOUR tenant (deploy + UCP test
# both target it). Multiple shells can run in parallel on different tenants;
# the per-tenant lock (tenant_lock.py) prevents same-tenant clobbering.
# =============================================================================


# -----------------------------------------------------------------------------
# UCP Connection / Tenant  (REQUIRED)
# -----------------------------------------------------------------------------
# Source: connectus/runtime_demisto.params_parity/xsoar_capture.py,
#         preflight_check.py (_REQUIRED_ENV), .env.example

# XSOAR/XSIAM tenant the test connects to (capture + mirror lookup).
DEMISTO_BASE_URL=https://your-tenant.xdr-qa2-uat.us.paloaltonetworks.com

# API key for the XSOAR/XSIAM tenant above.
DEMISTO_API_KEY=your-demisto-api-key-here

# XSIAM auth ID that pairs with DEMISTO_API_KEY.
XSIAM_AUTH_ID=1

# The single tenant (ICaaS) this shell deploys to and tests on. Sent to the
# GitLab pipeline internally as its TENANT_IDS variable.
TENANT_ID=1234567890123


# -----------------------------------------------------------------------------
# ConnectUs Repo  (REQUIRED — shared by param-parity, generate-manifest, validate)
# -----------------------------------------------------------------------------
# Source: deploy.py, resolver.py, preflight_check.py, workflow_state/gates.py

# Local clone of the unified-connectors-content repo. Used for the deploy git
# operations, the resolver (reads connector YAMLs from here), AND as the cwd for
# the `make validate` checkpoint gate. If unset, the validate gate falls back to
# the sibling-of-content-repo directory named `unified-connectors-content`.
CONNECTUS_REPO_DIR=/absolute/path/to/your/local/unified-connectors-content

# Branch IN THE CONNECTUS REPO that deploy.py force-pushes + deploys.
CONNECTUS_BRANCH=your-feature-branch


# -----------------------------------------------------------------------------
# Param Parity (deploy + capture + diff)
# -----------------------------------------------------------------------------
# Source: deploy.py, ucp_capture.py, main.py

# GitLab token (scope: api). Create at
# https://gitlab.xdr.pan.local/-/user_settings/personal_access_tokens
GITLAB_TOKEN=your-gitlab-personal-access-token

# GitLab base URL for triggering the deploy pipeline.
# Default if unset: https://gitlab.xdr.pan.local
# GITLAB_URL=https://gitlab.xdr.pan.local

# What CONNECTUS_BRANCH is reset to on every deploy.
# ⚠️  WARNING: every deploy runs `git reset --hard origin/<BASE_BRANCH>` on
#     CONNECTUS_BRANCH. This DISCARDS any local commits/changes on that branch
#     that are not on origin/<BASE_BRANCH>. Commit + push your connector changes
#     to the deployed branch first, or they will be wiped.
# Default if unset: stable
# BASE_BRANCH=stable

# Reason recorded for the deploy override in the GitLab pipeline.
# Default if unset: dev-testing
# OVERRIDE_REASON=dev-testing

# Port for the standalone UCP instance (create_ucp_instance.py legacy/ad-hoc
# usage; resolver-driven runs derive this instead).
# Default if unset: 8080
# UCP_PORT=8080

# Path to the XSOAR integration .yml to capture, when running main.py directly
# (can also be passed via CLI / edited in main.py).
# INTEGRATION_YML_PATH=Packs/MyPack/Integrations/MyInt/MyInt.yml


# -----------------------------------------------------------------------------
# Generate Manifest
# -----------------------------------------------------------------------------
# The generate-manifest step (connectus/connectus_migration/manifest_generator.py,
# run_pre_manifest_steps.py, manifest_generator_flow.md) is driven entirely by
# CLI arguments and repo-relative constants — it reads NO dedicated environment
# variables of its own. Its post-generation validate step (3d, `make validate`)
# reuses CONNECTUS_REPO_DIR (defined above) to locate the validator repo.


# -----------------------------------------------------------------------------
# Validate (self-executing checkpoint gates)
# -----------------------------------------------------------------------------
# Source: workflow_state/gates.py, self_executing_gates_design.md,
#         workflow_state/api.py, connectus-migration-SKILL.md

# The `make validate` checkpoint gate runs in CONNECTUS_REPO_DIR (see the
# ConnectUs Repo section above). No additional variable is needed for the
# normal validate path.

# Skip ALL self-executing checkpoint gates (e.g. `make validate`). Intended for
# exceptional cases only; set to 1 to bypass. Leave unset for normal runs.
# CONNECTUS_SKIP_CHECKPOINT_GATES=1

# Legacy escape hatch for the auth-parity gate inside set-auth. Set to 1 to
# request a bypass.
# TODO: confirm — docs (connectus-migration-SKILL.md) state this is now a no-op
#       for verification purposes since the gate short-circuits unconditionally,
#       so its effective behavior is ambiguous.
# CONNECTUS_SKIP_AUTH_PARITY=1
