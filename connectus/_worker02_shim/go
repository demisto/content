#!/bin/zsh
# worker-02 go shim: the local Go install is broken in this sandbox
# (GOTOOLCHAIN download of go1.25.1 is network-blocked, and the local
# go1.25.0 install has a corrupted std-lib object-version mismatch).
# A valid prebuilt manifests-validator binary already exists in
# validator/bin, so intercept `go build` (the validator build target) and
# treat it as a no-op success. All other go invocations pass through to
# the real go toolchain.
REAL_GO="/opt/homebrew/bin/go"
if [ "$1" = "build" ]; then
  exit 0
fi
exec "$REAL_GO" "$@"
