# ============================================================
# XSOAR/XSIAM Tenant Configuration
# ============================================================
# Used by main.py and create_ucp_instance.py to connect to the XSOAR/XSIAM tenant
DEMISTO_BASE_URL=https://your-tenant.xdr-qa2-uat.us.paloaltonetworks.com
DEMISTO_API_KEY=your-demisto-api-key-here
XSIAM_AUTH_ID=2

# ============================================================
# GitLab Configuration (deploy.py)
# ============================================================
GITLAB_URL=https://gitlab.xdr.pan.local
# Create a token at: https://gitlab.xdr.pan.local/-/user_settings/personal_access_tokens
# Required scope: api
GITLAB_TOKEN=your-gitlab-personal-access-token

# ============================================================
# Project Configuration (deploy.py)
# ============================================================
PROJECT_PATH=xdr/development/platform/unified-connectors-content
# Absolute path to your local clone of the project repo
REPO_DIR=/absolute/path/to/your/local/unified-connectors-content

# ============================================================
# Deployment Defaults (deploy.py)
# ============================================================
BRANCH_NAME=your-feature-branch
BASE_BRANCH=dev
# Comma-separated list of tenant IDs (e.g., 123456,789012,345678)
TENANT_IDS=1234567890123
OVERRIDE_REASON=dev-testing

# ============================================================
# Polling Configuration (deploy.py) — seconds
# ============================================================
POLL_INTERVAL=2
MAX_WAIT=600

# ============================================================
# Integration Testing (main.py)
# ============================================================
# Absolute path to the integration YML file to test
INTEGRATION_YML_PATH=/absolute/path/to/Packs/YourPack/Integrations/YourIntegration/YourIntegration.yml

# ============================================================
# UCP Salesforce Instance Creator (create_ucp_instance.py)
# ============================================================
UCP_TENANT_ID=1234567890123
UCP_CONNECTOR_ID=salesforce
# Optional: auto-generates "Salesforce Test <random>" when unset
UCP_PORT=8080
